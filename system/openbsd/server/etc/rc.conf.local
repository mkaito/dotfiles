# Rendered result of the `rcctl enable`/`rcctl set` lines below. Prefer driving
# this with rcctl rather than hand-editing:
#
#   rcctl enable httpd relayd forgejo
#   rcctl disable smtpd            # not a mail host
#
# pf is enabled via /etc/rc.conf (pf=YES, the default). ntpd/sshd are on by
# default. forgejo's rc script is installed by the local port.

httpd_flags=
relayd_flags=
forgejo_flags=
smtpd_flags=NO
pf=YES
