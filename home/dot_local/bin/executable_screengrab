#!/usr/bin/env zsh
set -euo pipefail

if [[ ! -t 0 ]]; then
  notify-send "Screengrab activated" "Drag region" || true
fi

tmp=$(mktemp --suffix=.png)
trap 'rm -f "$tmp"' EXIT

maim -s -m 1 "$tmp"
pngquant -f -o "$tmp" "$tmp"
xclip -selection clipboard -t image/png -i "$tmp"

mb=$(awk "BEGIN{printf \"%.2f\", $(stat -c %s "$tmp")/1048576}")
notify-send 'Screenshot' "Region copied to clipboard (${mb} MB)" || true
