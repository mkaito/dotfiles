#!/usr/bin/env zsh
set -euo pipefail

if [[ ! -t 0 ]]; then
  notify-send "Screengrab activated" "Drag region" || true
fi

tmp=$(mktemp --suffix=.png)
trap 'rm -f "$tmp"' EXIT

maim -s "$tmp"
xclip -selection clipboard -t image/png -i "$tmp"

notify-send 'Screenshot' 'Region copied to clipboard' || true
