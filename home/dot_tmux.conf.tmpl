unbind C-b
set -g prefix C-a
bind C-a last-window

set -g base-index 1
set -g pane-base-index 1

# Avoid login shell — macOS /etc/zprofile reorders PATH. Harmless on Linux.
set-option -g default-command "$SHELL"

# True colour + undercurl
set -g default-terminal "tmux-256color"
set -as terminal-features ",*256col*:RGB"
set -as terminal-features ",xterm-256color:RGB"
set -as terminal-overrides ',*:Smulx=\E[4::%p1%dm'
set -as terminal-overrides ',*:Setulc=\E[58::2::%p1%{65536}%/%d::%p1%{256}%/%{255}%&%d::%p1%{255}%&%d%;m'

# Fix nvim redraw
set -as terminal-overrides ',*:indn@'

# Cursor shape passthrough
set -as terminal-overrides ',*:Ss=\E[%p1%d q:Se=\E[2 q'

# Toggle status bar
set -g status on
bind t set status

set-option -g renumber-windows on
set-option -g allow-rename off
set -sg escape-time 0

setw -g mode-keys vi
setw -g mouse off

# OSC52 clipboard — WezTerm picks it up on macOS + Linux without xclip/pbcopy plumbing.
set -g set-clipboard on

# Swap windows
bind -n C-S-Left swap-window -t -1\; select-window -t -1
bind -n C-S-Right swap-window -t +1\; select-window -t +1

# Pane resizing
bind -r h resize-pane -L 5
bind -r j resize-pane -D 5
bind -r k resize-pane -U 5
bind -r l resize-pane -R 5

# Set pwd to current pane's path
bind C-c attach -c "#{pane_current_path}"

# Remove current window name from rename-window prompt
bind , command-prompt "rename-window '%%'"

# Pane joining
bind v choose-window "join-pane -h -s '%%'"

# Window cycling
bind -r n next-window
bind -r p previous-window

# Window swapping / session switching
bind S choose-tree -O name -w "swap-window -t '%%'"
bind s choose-tree -O name -s "switch-client -t '%%'"

# Clear screen
bind C-l send-keys 'C-l'

# Status bar
set-option -g status-style fg=white,bg=black,default
set-window-option -g window-status-style fg=white,bg=default,dim
set-window-option -g window-status-current-style fg=cyan,bg=default,dim
set-option -g message-style fg=white,bg=black,bright

set-option -g status-interval 30
set -g status-justify centre
set -g status-left-length 40
set -g status-left "#[bg=black]#{session_name} #{=22:pane_title}"
set-option -g display-time 1000

# Reload
bind-key r source-file ~/.tmux.conf \; display-message "Configuration reloaded"

# '@pane-is-vim' is a pane-local option set by smart-splits.nvim on load,
# unset when Neovim exits or suspends. Don't lazy-load that plugin.

# Smart pane switching with awareness of Neovim splits
bind-key -n C-h if -F "#{@pane-is-vim}" 'send-keys C-h'  'select-pane -L'
bind-key -n C-j if -F "#{@pane-is-vim}" 'send-keys C-j'  'select-pane -D'
bind-key -n C-k if -F "#{@pane-is-vim}" 'send-keys C-k'  'select-pane -U'
bind-key -n C-l if -F "#{@pane-is-vim}" 'send-keys C-l'  'select-pane -R'

# Smart pane resizing with awareness of Neovim splits
bind-key -n M-h if -F "#{@pane-is-vim}" 'send-keys M-h' 'resize-pane -L 3'
bind-key -n M-j if -F "#{@pane-is-vim}" 'send-keys M-j' 'resize-pane -D 3'
bind-key -n M-k if -F "#{@pane-is-vim}" 'send-keys M-k' 'resize-pane -U 3'
bind-key -n M-l if -F "#{@pane-is-vim}" 'send-keys M-l' 'resize-pane -R 3'

bind-key -n 'C-\' if -F "#{@pane-is-vim}" 'send-keys C-\\'  'select-pane -l'

bind-key -T copy-mode-vi 'C-h' select-pane -L
bind-key -T copy-mode-vi 'C-j' select-pane -D
bind-key -T copy-mode-vi 'C-k' select-pane -U
bind-key -T copy-mode-vi 'C-l' select-pane -R
bind-key -T copy-mode-vi 'C-\' select-pane -l

# Plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @plugin 'tmux-plugins/tmux-yank'
set -g @plugin 'tmux-plugins/tmux-open'

# Resurrect
set -g @resurrect-capture-pane-contents 'on'
# Restart these in restored panes. '~nvim' = match any nvim invocation
# (with args). resession.nvim then auto-loads the cwd-matching session.
set -g @resurrect-processes 'ssh psql mosh-client "~nvim"'

# Continuum — auto-save every 15 min, auto-restore on tmux server start
set -g @continuum-save-interval '15'
set -g @continuum-restore 'on'

source-file {{ .chezmoi.sourceDir | dir }}/vendor/tokyonight.nvim/extras/tmux/tokyonight_night.tmux

# Initialize TMUX plugin manager (keep this line at the very bottom of tmux.conf)
run '~/.tmux/plugins/tpm/tpm'

# vim: ft=tmux
