[global]
    font = Iosevka Term SS02 10
    frame_color = "#7aa2f7"
    separator_color = "#3b4261"

[urgency_low]
    background = "#1a1b26"
    foreground = "#a9b1d6"
    frame_color = "#3b4261"
    timeout = 4

[urgency_normal]
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#7aa2f7"
    timeout = 6

[urgency_critical]
    background = "#1a1b26"
    foreground = "#f7768e"
    frame_color = "#f7768e"
    timeout = 0
