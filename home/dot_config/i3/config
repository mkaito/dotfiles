# i3 config file (v4)
#
# Please see http://i3wm.org/docs/userguide.html for a complete reference!

set $mod Mod1

set $background #1a1b26
set $foreground #c0caf5
set $dim        #414868
set $accent     #7aa2f7
set $urgent     #f7768e

set $left  DisplayPort-1
set $right DisplayPort-2

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below. ISO 10646 = Unicode
#
#   font -misc-fixed-medium-r-normal--13-120-75-75-C-70-iso10646-1
#
# The font above is very space-efficient, that is, it looks good, sharp and
# clear in small sizes. However, if you need a lot of unicode glyphs or
# right-to-left text rendering, you should instead use pango for rendering and
# chose a FreeType font, such as:
# font pango:DejaVu Sans Mono 10

font pango:IosevkaTermSS02 Nerd Font 10

## Borders
new_window pixel 3
new_float pixel 5
hide_edge_borders both

# Colors
# Note: The drawn colour around windows is actually the background colour
# class                 border      background  text        indicator   child_border
client.background       $background
client.focused          $dim        $accent     $foreground $dim        $dim
client.focused_inactive $background $background $foreground $background $background
client.unfocused        $background $background $foreground $background $background
client.urgent           $background $urgent     $foreground $background $background

## Tap the key combo for the current workspace to go back to the previous one
workspace_auto_back_and_forth yes

## Don't warp the mouse to the center of a window when focusing another output
mouse_warping none

## Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

## Random programs and rules for them
# Note: `terminal` is ~/dev/bin/terminal, a bash script that launches my terminal.
bindsym $mod+F1 exec --no-startup-id terminal
bindsym $mod+F2 exec browser
# bindsym $mod+F3 exec --no-startup-id mail-emacs
# bindsym $mod+F3 exec --no-startup-id terminal mail   mutt
bindsym $mod+F3 exec --no-startup-id terminal mail   neomutt
bindsym $mod+F5 exec --no-startup-id terminal ranger ranger
bindsym $mod+F6 exec --no-startup-id terminal music  rmpc

bindsym $mod+F10 exec --no-startup-id anki

## Assign apps to workspaces.
## First match overrides.

# Browsers.
assign [class="^firefox$" instance="^Navigator$"] 3
assign [class="^Google-chrome$"] 3

# Make Firefox dialogs float
for_window [window_role="Dialog"] floating enable
for_window [window_role="GtkFileChooserDialog"] floating enable

# Messaging stuff
assign [instance="^mail$"] 4
assign [instance="^chat$"] 4
assign [instance="^nevermore"] 4
assign [class="^TeamSpeak 3$"] TS3
assign [class="^Mumble$"] Mumble
assign [class="^discord"] Discord
assign [class="^vesktop"] Discord
assign [class="^Slack"] Slack
assign [class="^Zulip"] Zulip
assign [class="^Telegram"] Telegram

# Anki
assign [class="^Anki$"] Anki
for_window [class="^Anki$" title="- Anki$"] floating disable, border none

# Development
assign [class="^VirtualBox Manager$"] vbox
assign [class="^Zeal$"] zeal

# Gaming
assign [class="^steam$"] Steam
assign [class="^FTL$"] 5
assign [title="^RimWorld"] 5
assign [title="^Shadowrun$"] 5
assign [class="^steam_app_"] 5
assign [class="^X4"] 5
assign [class="^Kingmaker.exe"] 5

assign [class="^Civ5XP$"] 5
assign [class="^Dwarf_Fortress$"] 5
assign [title="^cataclysm$"] 5

assign [instance="^ffxivlauncher.exe$"] 5
assign [instance="^ffxivboot.exe$"] 5
assign [instance="^ffxiv.exe$"] 5

assign [title="^Cities: Skylines$"] 5
assign [title="^Pillars of Eternity$"] 5
assign [title="^WORLD END ECONOMICA -I-$"] 5
assign [title="^Dysfunctional Systems | Episode 1: Learning to Manage Chaos$"] 5
assign [class="^Transistor.bin.x86_64$"] 5
for_window [class="^Transistor.bin.x86_64$"] floating disable border none
assign [class="^pshd$"] 5
assign [class="^factorio$"] 5
# for_window [title="^Factorio"] move to workspace 5
assign [class="^KingdomsAndCastles.x86$"] 5
assign [class="^XCOM: Enemy Unknown$"] 5
for_window [class="^XCOM: Enemy Unknown$"] floating disable border none

# catch-all for wine explorer
assign [instance="^explorer.exe$"] 5

# Random stuff
assign [class="^jd-Main$"] 6
assign [class="^JDownloader$"] 6
assign [class="^libprs500$"] 10
# assign [class="^mpv$"] 7
assign [class="^Deluge$"] 10
assign [instance="^libreoffice$"] Office
assign [instance="^calibre-gui$"] Calibre

# gimp
assign [class="Gimp"] gimp
for_window [title="GIMP Startup"] move workspace gimp
# for_window [window_role="gimp-toolbox"] floating disable; layout stacking; move left; resize shrink right 31px or 31 ppt

# Workaround for Spotify not setting window hints on tag
for_window [class="^Spotify$"] move to workspace Spotify

# Openshot
assign [class="^openshot"] 10
for_window [class="^openshot$" title="^Tutorial"] floating enable, border none

# OBS
assign [class="^obs$"] OBS

for_window [instance="^music$"] floating enable, border pixel 4
for_window [instance="^torrent$"] floating enable, border pixel 4
for_window [class="^mpv$"] floating enable, border none
for_window [class="^Galculator$"] floating enable, border pixel 4
for_window [class="^Wine$" instance="^explorer.exe$"] border none
for_window [class="^Pavucontrol$"] floating enable, border pixel 4
for_window [instance="^mixer"] floating enable, border pixel 4
for_window [class="^Pinentry-gtk-2$"] floating enable, border pixel 4
for_window [class="^Anki$"] floating enable
for_window [class="^Nitrogen$"] floating enable, border pixel 4
for_window [class="^Sxiv$" instance="^sxiv$"] floating enable, border pixel 4
for_window [class="^feh$" instance="^feh$"] floating enable, border pixel 4
for_window [class="^Steam$" title="^(?!Steam$)"] floating enable, border pixel 4
for_window [class="^FTL$"] floating enable, border pixel 4
for_window [class="^Mcomix$" title="^Library$"] floating enable, border pixel 4
for_window [class="^ffxiv.exe$"] floating disable, border none
for_window [class="^Client_tos.exe$"] floating disable, border none
for_window [class="^Xmessage$"] floating enable, border pixel 4
for_window [class="^Klavaro$"] floating enable, border pixel 4
for_window [class="^Steam Controller Configurator$"] floating enable, border pixel 4

# Why the heck would the entire game window be floating by default?
for_window [class="^Civ5XP$"] floating disable

# Makes for easier use of dialogs on the portrait screen. They have a habit of
# being too wide.
for_window [class="^Calibre-gui$"] floating disable

## Assign workspaces to monitors for convenience
workspace 1 output $left
workspace 3 output $left
workspace 4 output $right
workspace 5 output $left
workspace 6 output $right
workspace 7 output $left
workspace 10 output $right

workspace Anki output $right
workspace Calibre output $right
workspace Discord output $right
workspace Mumble output $right
workspace Office output $left
workspace Slack output $right
workspace Spotify output $right
workspace Steam output $right
workspace TS3 output $right
workspace gimp output $left
workspace vbox output $right


# Media keys
bindsym $mod+XF86AudioMute   exec --no-startup-id	terminal mixer wiremix
bindsym XF86AudioMute        exec --no-startup-id	wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioLowerVolume exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioRaiseVolume exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+

# mpd
bindsym XF86AudioPlay exec --no-startup-id		mpc toggle
bindsym XF86AudioPause exec --no-startup-id		mpc toggle
bindsym XF86AudioPrev exec --no-startup-id		mpc prev
bindsym XF86AudioNext exec --no-startup-id		mpc next

bindsym Print exec --no-startup-id 								screenshot
bindsym Shift+Print exec --no-startup-id 					screengrab

## kill focused window
bindsym $mod+Escape kill

## Toggle mod key
bindsym $mod+Shift+Tab exec --no-startup-id i3-toggle-mod

## start dmenu (a program launcher)
bindsym $mod+p exec --no-startup-id rofi -show run
bindsym $mod+Shift+p exec --no-startup-id rofi -show drun
bindsym $mod+Tab exec --no-startup-id rofi -show window

## change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
# bindsym $mod+Tab [urgent="oldest"] focus
# bindsym $mod+Tab exec --no-startup-id i3-focus-last.py --switch

## alternatively, you can use the cursor keys:
#bindsym $mod+Left focus left
#bindsym $mod+Down focus down
#bindsym $mod+Up focus up
#bindsym $mod+Right focus right

## move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

## alternatively, you can use the cursor keys:
#bindsym $mod+Shift+Left move left
#bindsym $mod+Shift+Down move down
#bindsym $mod+Shift+Up move up
#bindsym $mod+Shift+Right move right

## split in horizontal orientation
bindsym $mod+Control+h split h

## split in vertical orientation
bindsym $mod+Control+v split v

## enter fullscreen mode for the focused container
bindsym $mod+f fullscreen

## change container layout (stacked, tabbed, toggle split)
#bindsym $mod+s layout stacking
#bindsym $mod+w layout tabbed
#bindsym $mod+e layout toggle split

## toggle tiling / floating
bindsym $mod+Shift+space floating toggle

## change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

## focus the parent container
# bindsym $mod+a focus parent

## focus the child container
#bindsym $mod+d focus child

# This should work even on client windows
# bindsym --whole-window $mod+button5 workspace next_on_output
# bindsym --whole-window $mod+button4 workspace prev_on_output

## switch to workspace
bindsym $mod+1 workspace 1
bindsym $mod+2 workspace 2
bindsym $mod+3 workspace 3
bindsym $mod+4 workspace 4
bindsym $mod+5 workspace 5
bindsym $mod+6 workspace 6
bindsym $mod+7 workspace 7
bindsym $mod+8 workspace 8
bindsym $mod+9 workspace 9
bindsym $mod+0 workspace 10

## move focused container to workspace
bindsym $mod+Shift+1 move container to workspace 1
bindsym $mod+Shift+2 move container to workspace 2
bindsym $mod+Shift+3 move container to workspace 3
bindsym $mod+Shift+4 move container to workspace 4
bindsym $mod+Shift+5 move container to workspace 5
bindsym $mod+Shift+6 move container to workspace 6
bindsym $mod+Shift+7 move container to workspace 7
bindsym $mod+Shift+8 move container to workspace 8
bindsym $mod+Shift+9 move container to workspace 9
bindsym $mod+Shift+0 move container to workspace 10

bindsym $mod+period focus output right
bindsym $mod+comma focus output left
bindsym $mod+Shift+period move container to output right
bindsym $mod+Shift+comma move container to output left
bindsym $mod+Control+period move workspace to output right
bindsym $mod+Control+comma move workspace to output left

## reload the configuration file
bindsym $mod+Control+c reload
## restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Control+r restart
## exit i3 (logs you out of your X session)
bindsym $mod+Control+q exit
#bindsym $mod+Control+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -b 'Yes, exit i3' 'i3-msg exit'"

## resize window (you can also use the mouse for that)
mode "resize" {
# These bindings trigger as soon as you enter the resize mode

# Pressing left will shrink the window’s width.
# Pressing right will grow the window’s width.
# Pressing up will shrink the window’s height.
# Pressing down will grow the window’s height.
  bindsym h resize shrink width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt

# same bindings, but for the arrow keys
    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt

# back to normal: Enter or Escape
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

bindsym $mod+r mode "resize"

exec --no-startup-id openrc --user graphical
