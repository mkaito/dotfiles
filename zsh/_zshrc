fpath=("$HOME/dev/dotfiles/zsh/completion" $fpath)

source "${HOME}/dev/build/zgenom/zgenom.zsh"

source ~/.zshenv

if ! zgenom saved; then
    echo "Creating a zgenom save"

    zgenom oh-my-zsh

    # plugins
    zgenom ohmyzsh plugins/sudo
    zgenom ohmyzsh plugins/git-escape-magic

    zgenom load zsh-users/zsh-syntax-highlighting
    zgenom load mafredri/zsh-async

    # Prompt
    zgenom load sindresorhus/pure

    # completions
    zgenom load zsh-users/zsh-completions src

    # FZF history search
    zgenom load unixorn/fzf-zsh-plugin

    # save all to init script
    zgenom save
fi

# Show git stash in the prompt
zstyle :prompt:pure:git:stash show yes

# Tokyo Night colors for Pure prompt
zstyle :prompt:pure:path color blue
zstyle :prompt:pure:prompt:success color cyan
zstyle :prompt:pure:prompt:error color red
zstyle :prompt:pure:git:branch color magenta
zstyle :prompt:pure:git:arrow color cyan
zstyle :prompt:pure:git:stash color cyan
zstyle :prompt:pure:git:action color yellow
zstyle :prompt:pure:git:dirty color yellow
zstyle :prompt:pure:host color blue
zstyle :prompt:pure:user color blue
zstyle :prompt:pure:virtualenv color cyan
zstyle :prompt:pure:execution_time color yellow

setopt nohup
setopt autocd
setopt noclobber
setopt autopushd pushdminus pushdsilent pushdtohome
setopt histreduceblanks histignorespace inc_append_history

# Save history basically forever
HISTFILE=~/.zsh_history
HISTSIZE=999999999
SAVEHIST=$HISTSIZE

# This is the default, but since the commands below rely on it, make sure it's
# bound to what we think it is.
bindkey "^Q" push-line
bindkey -s "^[l" "^Qls -l^J"
bindkey -s "^l" "^Qclear^J"

source ~/dev/dotfiles/zsh/_alias

autoload -Uz compinit; compinit

# z jump
eval "$(zoxide init zsh)"

# Enable completion caching
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path ~/.zsh/cache

# Disable hostname completion, because it's slow
zstyle ':completion:*' hosts off

# Quick completions
compdef gpg2=gpg

# God bless _gnu_generic
compdef _gnu_generic transmission-remote

# git-fixup
zstyle ':completion:*:*:git:*' user-commands fixup:'Create a fixup commit'

#  * List of completers to use
zstyle ":completion:*" completer _complete _match _approximate
#  * Allow approximate
zstyle ":completion:*:match:*" original only
zstyle ":completion:*:approximate:*" max-errors 1 numeric
#  * Selection prompt as menu
zstyle ":completion:*" menu select=1
#  * Menu selection for PID completion
zstyle ":completion:*:*:kill:*" menu yes select
zstyle ":completion:*:kill:*" force-list always
zstyle ":completion:*:processes" command "ps -au$USER"
zstyle ":completion:*:*:kill:*:processes" list-colors "=(#b) #([0-9]#)*=0=01;32"
#  * Don't select parent dir on cd
zstyle ":completion:*:cd:*" ignore-parents parent pwd
#  * Complete with colors
zstyle ":completion:*" list-colors ""

# fzf-tab config
zstyle ':fzf-tab:*' fzf-bindings \
	'ctrl-j:down' \
	'ctrl-k:up' \
	'ctrl-l:accept'

test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

# mise en place
MISE="$(command -v mise)"
eval "$($MISE activate zsh)"

function gi() { curl -sLw "\n" https://www.toptal.com/developers/gitignore/api/$@ ;}

# fzf shell integration - explicit paths for system-installed fzf
if command -v fzf &>/dev/null; then
    # Try modern fzf --zsh first (fzf >= 0.48)
    source <(fzf --zsh)
fi

