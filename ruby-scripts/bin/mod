#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
require "optparse"
require "fileutils"
require "set"
require_relative "../lib/core/cli"
require_relative "../lib/mod_manager/errors"
require_relative "../lib/mod_manager/log"
require_relative "../lib/mod_manager/config"
require_relative "../lib/mod_manager/mod"
require_relative "../lib/mod_manager/archive"
require_relative "../lib/mod_manager/atom"
require_relative "../lib/mod_manager/collection"
require_relative "../lib/mod_manager/collection_editor"
require_relative "../lib/mod_manager/modset"
require_relative "../lib/mod_manager/topo_sort"
require_relative "../lib/mod_manager/deployer"
require_relative "../lib/mod_manager/checker"
require_relative "../lib/mod_manager/verifier"
require_relative "../lib/nexus/client"
require_relative "../lib/nexus/installer"

include ModManager

NEXUS_ENV_FILE = File.join(Core::XDG.config_home, "mods", "nexus.env")

def nexus_client
  key = ENV["NEXUS_API_KEY"] or raise Core::Error, <<~MSG.chomp
    NEXUS_API_KEY not set. Options:
      1. op run --env-file=#{NEXUS_ENV_FILE} -- mod nexus ...
         (create #{NEXUS_ENV_FILE} with: NEXUS_API_KEY=op://Private/Nexusmods/add more/API Key)
      2. NEXUS_API_KEY="op://Private/Nexusmods/add more/API Key" op run -- mod nexus ...
  MSG
  Nexus::Client.new(key)
end

def cmd_nexus_download(game_domain, mod_id, file_index:, slug:)
  config, archive = load_context
  client  = nexus_client
  files   = client.mod_files(game_domain, mod_id)
  sorted  = Nexus::Installer.sort_files(files)

  file = if file_index
    sorted[file_index - 1] or raise Core::Error, "--file #{file_index}: out of range (1-#{sorted.size})"
  else
    Nexus::Installer.auto_select(sorted) or begin
      Nexus::Installer.print_file_list(sorted)
      exit 1
    end
  end

  installed_slug, version = Nexus::Installer.install(
    client, game_domain, mod_id,
    archive_dir: config.archive_dir, file_id: file["file_id"], slug: slug
  )
  archive.invalidate
  puts "installed #{installed_slug}"
end

def cmd_nexus_update(slugs)
  config, archive = load_context
  client = nexus_client
  candidates = archive.all.select { _1.source["provider"] == "nexus" }
  candidates = candidates.select { slugs.include?(_1.slug) } if slugs.any?

  if candidates.empty?
    puts "no nexus-sourced mods in archive#{slugs.any? ? " matching #{slugs.join(", ")}" : ""}"
    return
  end

  candidates.each do |mod|
    src          = mod.source
    game_domain  = src["game_domain"]
    mod_id       = src["mod_id"]
    category     = src["category_name"] || "MAIN"
    installed_ts = src["uploaded_at"].to_i

    all_files = client.mod_files(game_domain, mod_id)
    track     = all_files.select { _1["category_name"] == category }
    track     = all_files if track.empty?
    latest    = track.max_by { _1["uploaded_timestamp"].to_i }

    if latest["uploaded_timestamp"].to_i <= installed_ts
      puts "#{mod.slug}: up to date"
    else
      new_slug, _ = Nexus::Installer.install(
        client, game_domain, mod_id,
        archive_dir: config.archive_dir, file_id: latest["file_id"]
      )
      puts "#{mod.slug} → #{new_slug}"
    end
  end
  archive.invalidate
end

def load_context
  config  = Config.load
  archive = Archive.new(config.archive_dir)
  [config, archive]
end

def cmd_deploy(modset_name)
  config, archive = load_context
  path = File.join(config.modsets_dir, "#{modset_name}.toml")
  raise Error, "modset not found: #{path}" unless File.exist?(path)
  ms = Modset.load(path)

  check_errors = Checker.new(archive, config).check_modset(ms)
  if check_errors.any?
    check_errors.each { puts "  #{_1}" }
    exit 1
  end

  mods, collections = ms.resolve(archive, config)
  deployer = Deployer.new(config.game_dir, config.archive_dir)
  result   = deployer.deploy(mods)

  puts "#{result[:created]} symlink(s) from #{mods.size} mod(s)"

  checks  = Verifier.collect(config, ms, collections)
  vfails  = Verifier.run(checks, config.game_dir)
  if vfails.any?
    puts "verify warnings (#{vfails.size}):"
    vfails.each { puts "  #{_1}" }
  end

  result[:broken].each { Log.warn("broken: #{_1}") }
end

def cmd_reset(yes:)
  config, = load_context
  deployer = Deployer.new(config.game_dir, config.archive_dir)
  st = deployer.status
  total = st.values.sum { _1[:links].size + _1[:broken].size }

  if total.zero?
    puts "no active symlinks"
    return
  end

  puts "#{total} symlink(s) to remove"
  unless yes || Core::CLI.confirm("proceed?")
    puts "aborted"
    return
  end

  puts "removed #{deployer.undeploy} symlink(s)"
end

def cmd_status
  config, = load_context
  st = Deployer.new(config.game_dir, config.archive_dir).status

  if st.empty?
    puts "no active mods"
    return
  end

  st.each do |slug_ver, data|
    suffix = data[:broken].any? ? ", #{data[:broken].size} broken" : ""
    puts "#{slug_ver}: #{data[:links].size} link(s)#{suffix}"
    data[:broken].each { puts "  broken: #{_1}" }
  end
end

def cmd_validate(name = nil)
  config, archive = load_context
  checker = Checker.new(archive, config)

  errors = if name
    path = File.join(config.modsets_dir, "#{name}.toml")
    if File.exist?(path)
      checker.check_modset(Modset.load(path))
    else
      path = File.join(config.collections_dir, "#{name}.toml")
      raise Error, "no modset or collection named #{name.inspect}" unless File.exist?(path)
      checker.check_collection(Collection.load(path))
    end
  else
    checker.check_all
  end

  if errors.empty?
    puts "ok"
  else
    errors.each { puts "  #{_1}" }
    exit 1
  end
end

def cmd_collection_add(collection_name, atom_str)
  config, archive = load_context
  path = File.join(config.collections_dir, "#{collection_name}.toml")
  raise Error, "collection not found: #{path}" unless File.exist?(path)
  CollectionEditor.add(path, atom_str, archive)
  puts "updated #{collection_name}"
end

def cmd_collection_remove(collection_name, slug)
  config, archive = load_context
  path = File.join(config.collections_dir, "#{collection_name}.toml")
  raise Error, "collection not found: #{path}" unless File.exist?(path)
  CollectionEditor.remove(path, slug, archive)
  puts "updated #{collection_name}"
end

def cmd_cleanup(dry_run:, yes:)
  config, archive = load_context
  referenced = Set.new

  Dir.glob("#{config.collections_dir}/*.toml").each do |p|
    Collection.load(p).mods.each { referenced << Atom.parse(_1)[:slug] }
  rescue ValidationError => e
    e.errors.each { Log.warn(_1) }
  end
  Dir.glob("#{config.modsets_dir}/*.toml").each do |p|
    Modset.load(p).mods.each { referenced << Atom.parse(_1)[:slug] }
  rescue ValidationError => e
    e.errors.each { Log.warn(_1) }
  end

  orphans = archive.all.reject { referenced.include?(_1.slug) }

  if orphans.empty?
    puts "no orphaned mods"
    return
  end

  puts "orphaned (#{orphans.size}):"
  orphans.each { puts "  #{_1}" }
  return if dry_run

  unless yes || Core::CLI.confirm("delete #{orphans.size} mod(s)?")
    puts "aborted"
    return
  end

  orphans.each do |mod|
    FileUtils.rm_rf(mod.path)
    parent = File.dirname(mod.path)
    Dir.rmdir(parent) if Dir.empty?(parent)
    Log.info("deleted #{mod}")
  end
  puts "deleted #{orphans.size} mod(s)"
end

subcommand = ARGV.shift

begin
  case subcommand
  when "deploy"
    abort("usage: mod deploy <modset>") if ARGV.empty?
    cmd_deploy(ARGV.first)

  when "reset"
    opts = { yes: false }
    OptionParser.new { |o| o.on("-y", "--yes") { opts[:yes] = true } }.parse!(ARGV)
    cmd_reset(**opts)

  when "status"
    cmd_status

  when "validate"
    cmd_validate(ARGV.first)

  when "collection"
    action = ARGV.shift
    case action
    when "add"
      abort("usage: mod collection add <collection> <atom>") if ARGV.size < 2
      cmd_collection_add(ARGV[0], ARGV[1])
    when "remove"
      abort("usage: mod collection remove <collection> <slug>") if ARGV.size < 2
      cmd_collection_remove(ARGV[0], ARGV[1])
    else
      abort("usage: mod collection <add|remove> ...")
    end

  when "cleanup"
    opts = { dry_run: false, yes: false }
    OptionParser.new do |o|
      o.on("-n", "--dry-run") { opts[:dry_run] = true }
      o.on("-y", "--yes")     { opts[:yes] = true }
    end.parse!(ARGV)
    cmd_cleanup(**opts)

  when "nexus"
    action = ARGV.shift
    case action
    when "download"
      opts = { file_index: nil, slug: nil }
      OptionParser.new do |o|
        o.on("--file N", Integer) { opts[:file_index] = _1 }
        o.on("--slug SLUG")       { opts[:slug] = _1 }
      end.parse!(ARGV)
      abort("usage: mod nexus download <game_domain> <mod_id>") if ARGV.size < 2
      cmd_nexus_download(ARGV[0], ARGV[1].to_i, **opts)
    when "update"
      cmd_nexus_update(ARGV)
    else
      abort("usage: mod nexus <download|update> ...")
    end

  when "update"
    cmd_nexus_update(ARGV)

  else
    abort("usage: mod <deploy|reset|status|validate|collection|cleanup|nexus|update>")
  end
rescue ValidationError => e
  e.errors.each { puts "  #{_1}" }
  exit 1
rescue Error => e
  abort(e.message)
end
