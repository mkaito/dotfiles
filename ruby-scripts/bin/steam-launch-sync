#!/usr/bin/env ruby
# frozen_string_literal: true

require "core/errors"
require "core/log"
require "core/file_io"
require "steam/vdf"
require "steam/backup"

VDF_PATHS = [
  "~/.local/share/Steam/userdata/*/config/localconfig.vdf",
  "~/.steam/steam/userdata/*/config/localconfig.vdf"
].freeze

def find_vdf
  VDF_PATHS.each do |pattern|
    found = Dir.glob(File.expand_path(pattern)).first
    return found if found
  end
  raise Core::Error, "localconfig.vdf not found (checked: #{VDF_PATHS.join(", ")})"
end

def cmd_import(backup_file)
  options = Steam::Vdf.launch_options(File.read(find_vdf))
  Steam::Backup.save(backup_file, options)
  puts "imported #{options.size} launch option(s) → #{backup_file}"
end

def cmd_export(backup_file)
  backup = Steam::Backup.load(backup_file)

  if system("pgrep", "-x", "steam", out: File::NULL, err: File::NULL)
    raise Core::Error, "Steam is running. Quit Steam before exporting."
  end

  vdf_path = find_vdf
  original = File.read(vdf_path)
  result = Steam::Vdf.apply_launch_options(original, backup)

  validate!(original, result, backup)
  Core::FileIO.atomic_write(vdf_path, result[:src])

  Core::Log.warn("skipped #{result[:skipped].size} appid(s) not installed: #{result[:skipped].join(", ")}") if result[:skipped].any?
  puts "exported #{result[:applied]} launch option(s) → #{vdf_path}"
end

# Re-read the edited VDF and prove the edit did exactly what was asked and
# nothing else structural changed. Raise (and never write) on any discrepancy.
def validate!(original, result, backup)
  new_src = result[:src]

  if Steam::Vdf.app_ids(new_src).sort != Steam::Vdf.app_ids(original).sort
    raise Core::Error, "validation failed: app set changed. VDF not written."
  end

  after = Steam::Vdf.launch_options(new_src)
  backup.each do |appid, value|
    next if result[:skipped].include?(appid)
    unless after[appid] == value
      raise Core::Error, "validation failed: #{appid} did not round-trip. VDF not written."
    end
  end
end

begin
  command, backup_file, * = ARGV
  raise Core::Error, "usage: steam-launch-sync <import|export> <backup-file>" if backup_file.to_s.empty?

  case command
  when "import" then cmd_import(backup_file)
  when "export" then cmd_export(backup_file)
  else raise Core::Error, "usage: steam-launch-sync <import|export> <backup-file>"
  end
rescue Core::Error => e
  abort(e.message)
end
